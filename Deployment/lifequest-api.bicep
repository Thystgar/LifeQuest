param environment string

targetScope = 'resourceGroup'

resource containerIdentity 'Microsoft.ManagedIdentity/userAssignedIdentities@2024-11-30' existing =  {
  name: 'lifequest-${environment}-api'
  scope: resourceGroup('lifequest-identity')
}

resource logsWorkspace 'Microsoft.OperationalInsights/workspaces@2023-09-01' existing = {
  name: 'lifequest-logs'
  scope: resourceGroup('lifequest-shared')
}

resource container 'Microsoft.ContainerInstance/containerGroups@2024-10-01-preview' = {
  name: 'lifequest-${environment}-container'
  location: resourceGroup().location
  identity: {
    type: 'UserAssigned'
    userAssignedIdentities: {
      '${containerIdentity.id}': {}
    }
  }
  properties: {
    sku: 'Standard'
    containers: [
      {
        name: 'lifequest-api-container'
        properties: {
          image: 'lifequest.azurecr.io/lifequest-api:latest'
          ports: [
            {
              protocol: 'TCP'
              port: 8080
            }
          ]
          resources: {
            requests: {
              memoryInGB: json('1.5')
              cpu: json('1')
            }
          }
          environmentVariables: [
            {
              name: 'ASPNETCORE_ENVIRONMENT'
              value: environment
            }
          ]
        }
      }
    ]
    imageRegistryCredentials: [
      {
        server: 'lifequest.azurecr.io'
        identity: containerIdentity.id
      }
    ]
    ipAddress: {
      ports: [
        {
          protocol: 'TCP'
          port: 8080
        }
      ]
      type: 'Public'
      dnsNameLabel: 'lifequest-${environment}'
      autoGeneratedDomainNameLabelScope: 'TenantReuse'
    }
    diagnostics: {
      logAnalytics: {
        workspaceId: 'bda467de-0e89-4f08-8683-c2b78887a80f'
        logType: 'ContainerInstanceLogs'
        workspaceKey: logsWorkspace.listKeys().primarySharedKey
      }
    }
    osType: 'Linux'
    restartPolicy: 'OnFailure'
  }
}
