{
  "expo": {
    "name": "lifequestapp",
    "slug": "lifequestapp",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "src/assets/images/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "scheme": "com.lifequestapp",
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.lifequestapp"
    },
    "plugins": [
      "expo-asset",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#ffffff",
          "image": "src/assets/images/icon.png"
        }
      ]
    ]
  }
}
